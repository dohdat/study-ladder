{
  "name": "study-ladder-extension",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "prepare:monaco": "node scripts/copy-monaco.mjs",
    "install:native-host": "node native/install-native-host.mjs",
    "reload:extension": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reload-extension.ps1",
    "dev": "npm run dev:extension",
    "dev:web": "npm run prepare:monaco && vite --host 127.0.0.1 --port 3000",
    "dev:extension": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-reload-extension.ps1",
    "dev:extension:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watch-extension.ps1",
    "dev:extension:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-reload-extension.ps1 -FullBuild",
    "build": "npm run prepare:monaco && vite build",
    "build:fast": "vite build",
    "reload:fast": "npm run dev:extension",
    "lint": "eslint .",
    "start": "vite preview --host 127.0.0.1 --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tabler/icons-react": "^3.31.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.8.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
